# Essence Configuration
# Copy to .env and customize as needed

# Server
PORT=8080
RUST_LOG=essence=info

# Browser Engine (requires Chromium installed)
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=5
BROWSER_TIMEOUT_MS=30000

# Engine Waterfall (HTTP -> Browser fallback)
ENGINE_WATERFALL_ENABLED=true
ENGINE_WATERFALL_DELAY_MS=5000

# Crawler
CRAWL_RATE_LIMIT_PER_SEC=2
CRAWL_MAX_DURATION_SEC=300
MAX_CONCURRENT_REQUESTS=10

# Search
MAX_PARALLEL_SCRAPES=5

# Request Limits
MAX_REQUEST_SIZE_MB=1
